# ==========================================================
# Service360 - Salesforce DX .gitignore
# ==========================================================

# ----------------------------------------------------------
# Salesforce CLI
# ----------------------------------------------------------
.sf/
.sfdx/
.localdevserver/
deploy-options.json

# ----------------------------------------------------------
# Salesforce Auth (if used)
# ----------------------------------------------------------
.auth/

# ----------------------------------------------------------
# LWC
# ----------------------------------------------------------
**/lwc/jsconfig.json

# ----------------------------------------------------------
# Test Coverage
# ----------------------------------------------------------
coverage/
test-results/

# ----------------------------------------------------------
# Node.js
# ----------------------------------------------------------
node_modules/
.npm/

# ----------------------------------------------------------
# Logs
# ----------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ----------------------------------------------------------
# PMD / ESLint
# ----------------------------------------------------------
.pmdCache
.eslintcache

# ----------------------------------------------------------
# Environment Variables
# ----------------------------------------------------------
.env
.env.*

# ----------------------------------------------------------
# Python (Salesforce Functions)
# ----------------------------------------------------------
**/__pycache__/
**/.venv/
**/venv/

# ----------------------------------------------------------
# Temporary Files
# ----------------------------------------------------------
*.tmp
*.temp
*.bak
*.swp

# ----------------------------------------------------------
# macOS
# ----------------------------------------------------------
.DS_Store

# ----------------------------------------------------------
# Windows
# ----------------------------------------------------------
Thumbs.db
ehthumbs.db
[Dd]esktop.ini
$RECYCLE.BIN/

# ----------------------------------------------------------
# IDE Local History
# ----------------------------------------------------------
.history/

# ==========================================================
# IMPORTANT:
# Do NOT ignore these folders. They contain the project
# source code and must be committed to Git.
#
# force-app/
# config/
# scripts/
# manifest/
# .vscode/
# ==========================================================