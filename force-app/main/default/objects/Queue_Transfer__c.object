<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <deploymentStatus>Deployed</deploymentStatus>
    <description>Tracks transfers between queues.</description>
    <enableActivities>true</enableActivities>
    <enableHistory>true</enableHistory>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <enableSharing>true</enableSharing>
    <label>Queue Transfer</label>
    <nameField>
        <displayFormat>QT-{0000000}</displayFormat>
        <label>Transfer ID</label>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>Queue Transfers</pluralLabel>
    <sharingModel>ReadWrite</sharingModel>
    <fields>
        <fullName>From_Queue__c</fullName>
        <label>From Queue</label>
        <length>255</length>
        <type>Text</type>
    </fields>
    <fields>
        <fullName>To_Queue__c</fullName>
        <label>To Queue</label>
        <length>255</length>
        <type>Text</type>
    </fields>
    <fields>
        <fullName>Transfer_Time__c</fullName>
        <label>Transfer Time</label>
        <type>DateTime</type>
    </fields>
    <fields>
        <fullName>Agent__c</fullName>
        <deleteConstraint>SetNull</deleteConstraint>
        <label>Agent</label>
        <referenceTo>User</referenceTo>
        <relationshipName>Queue_Transfers</relationshipName>
        <required>false</required>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>Interaction__c</fullName>
        <deleteConstraint>SetNull</deleteConstraint>
        <label>Interaction</label>
        <referenceTo>Interaction__c</referenceTo>
        <relationshipLabel>Queue Transfers</relationshipLabel>
        <relationshipName>Queue_Transfers</relationshipName>
        <required>false</required>
        <type>Lookup</type>
    </fields>
</CustomObject>
