<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <deploymentStatus>Deployed</deploymentStatus>
    <description>Stores communication consent.</description>
    <enableActivities>true</enableActivities>
    <enableHistory>true</enableHistory>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <enableSharing>true</enableSharing>
    <label>Customer Consent</label>
    <nameField>
        <displayFormat>CC-{0000000}</displayFormat>
        <label>Consent ID</label>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>Customer Consents</pluralLabel>
    <sharingModel>ReadWrite</sharingModel>
    <fields>
        <fullName>Contact__c</fullName>
        <deleteConstraint>SetNull</deleteConstraint>
        <label>Contact</label>
        <referenceTo>Contact</referenceTo>
        <relationshipLabel>Customer Consents</relationshipLabel>
        <relationshipName>Customer_Consents</relationshipName>
        <required>false</required>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>SMS__c</fullName>
        <defaultValue>false</defaultValue>
        <label>SMS</label>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Email__c</fullName>
        <defaultValue>false</defaultValue>
        <label>Email</label>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Call_Recording__c</fullName>
        <defaultValue>false</defaultValue>
        <label>Call Recording</label>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>WhatsApp__c</fullName>
        <defaultValue>false</defaultValue>
        <label>WhatsApp</label>
        <type>Checkbox</type>
    </fields>
</CustomObject>
